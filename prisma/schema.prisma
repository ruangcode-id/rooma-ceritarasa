// =============================================
// Prisma Schema — Sistem Reservasi Restoran
// ERD FINAL v2 — 100% Match
// =============================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------
// ENUMS
// -----------------------------------------------

enum UserRole {
  admin
  owner
}

enum ReservationStatus {
  pending
  confirmed
  checked_in
  no_show
  cancelled
}

enum PaymentType {
  deposit
  full
  refund
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum GalleryCategory {
  food
  interior
  event
  team
}

enum VipTier {
  SILVER
  GOLD
  PLATINUM
}

enum CareerApplicationStatus {
  NEW
  REVIEWED
  ACCEPTED
  REJECTED
}

enum NotificationType {
  new_reservation
  cancellation
  check_in
  payment_confirmed
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

// -----------------------------------------------
// 1. AUTH — hanya admin & owner
// -----------------------------------------------

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  password  String   @db.Text
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  accounts            Account[]
  sessions            UserSession[]
  settingsUpdated     RestaurantSetting[] @relation("UpdatedByUser")
  blockedDates        BlockedDate[]       @relation("CreatedByUser")
  reservationsCreated Reservation[]       @relation("CreatedByUser")
  checkIns            CheckIn[]           @relation("CheckedInByUser")
  galleryPhotos       GalleryPhoto[]      @relation("UploadedByUser")
  eventsCreated       Event[]             @relation("CreatedByUser")
  jobListings         JobListing[]        @relation("CreatedByUser")
  notifications       Notification[]      @relation("UserNotifications")
  pushSubscriptions   PushSubscription[]  @relation("UserPushSubscriptions")

  @@map("users")
}

// -----------------------------------------------
// 2. TAMU — tidak login, data dari form reservasi
// -----------------------------------------------

model Guest {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @db.VarChar(100)
  email     String?   @db.VarChar(150)
  // Unique hanya untuk guest aktif (diatur lewat partial unique index pada migration SQL).
  phone     String    @db.VarChar(20)
  birthdate DateTime? @db.Date
  isVip     Boolean   @default(false) @map("is_vip")
  notes     String?   @db.Text
  tags      String[]  @default([])
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  vipCard       VipCard?
  reservations  Reservation[]
  guestNotes    GuestNote[]

  @@map("guests")
}

model GuestNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guestId   String   @map("guest_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  guest Guest @relation(fields: [guestId], references: [id])

  @@index([guestId, createdAt], map: "idx_guest_notes_guest_created")
  @@map("guest_notes")
}

model VipCard {
  id        String   @id @default(uuid()) @db.Uuid
  guestId   String   @unique @map("guest_id") @db.Uuid
  tier      VipTier  @default(SILVER)
  token     String   @unique @db.VarChar(100)
  qrCodeUrl String?  @map("qr_code_url") @db.Text
  benefits  String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  issuedAt  DateTime @default(now()) @map("issued_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("vip_cards")
}

// -----------------------------------------------
// 3. KONFIGURASI RESTORAN
// -----------------------------------------------

model RestaurantSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String?  @db.VarChar(100)
  address              String?  @db.Text
  phone                String?  @db.VarChar(20)
  email                String?  @db.VarChar(150)
  whatsappNumber       String?  @map("whatsapp_number") @db.VarChar(20)
  logoUrl              String?  @map("logo_url") @db.Text
  tagline              String?  @db.VarChar(255)
  socialLinks          Json?    @map("social_links")
  operatingHours       Json?    @map("operating_hours")
  maxGuestsPerDay      Int?     @map("max_guests_per_day")
  depositPercent       Decimal? @map("deposit_percent") @db.Decimal(5, 2)
  cancellationPolicy   String?  @map("cancellation_policy") @db.Text
  seoTitle             String?  @map("seo_title") @db.VarChar(200)
  seoDescription       String?  @map("seo_description") @db.Text
  confirmationTemplate String?  @map("confirmation_template") @db.Text
  reminderTemplate     String?  @map("reminder_template") @db.Text
  waTemplates          Json?    @map("wa_templates")
  emailTemplates       Json?    @map("email_templates")
  updatedAt            DateTime @updatedAt @map("updated_at")
  updatedBy            String?  @map("updated_by") @db.Uuid

  // Relations
  updater User? @relation("UpdatedByUser", fields: [updatedBy], references: [id])

  @@map("restaurant_settings")
}

model RestaurantSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(50)
  startTime   DateTime @map("start_time") @db.Time()
  endTime     DateTime @map("end_time") @db.Time()
  maxCapacity Int      @map("max_capacity")
  isActive    Boolean  @default(true) @map("is_active")
  dayOfWeek   Int[]    @map("day_of_week")

  // Relations
  reservations  Reservation[]

  @@map("restaurant_sessions")
}

model BlockedDate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date      DateTime @db.Date
  reason    String?  @db.VarChar(200)
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  creator User? @relation("CreatedByUser", fields: [createdBy], references: [id])

  @@map("blocked_dates")
}

// -----------------------------------------------
// 4. MEJA
// -----------------------------------------------

model Table {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableNumber String      @unique @map("table_number") @db.VarChar(10)
  capacity    Int
  posX        Int?        @map("position_x")
  posY        Int?        @map("position_y")
  isActive    Boolean     @default(true) @map("is_active")
  status      TableStatus @default(AVAILABLE)

  // Relations
  reservationTables ReservationTable[]

  @@map("tables")
}

// -----------------------------------------------
// 5. RESERVASI
// -----------------------------------------------

model Reservation {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guestId        String            @map("guest_id") @db.Uuid
  sessionId      String            @map("session_id") @db.Uuid
  date           DateTime          @db.Date
  partySize      Int               @map("party_size")
  status         ReservationStatus
  specialRequest String?           @map("special_request") @db.Text
  internalNotes  String?           @map("internal_notes") @db.Text
  cancelToken    String?           @unique @map("cancel_token") @db.VarChar(100)
  paymentToken   String?           @unique @map("payment_token") @db.VarChar(100)
  expiresAt      DateTime?         @map("expires_at")
  reminderSentAt DateTime?         @map("reminder_sent_at")
  createdBy      String?           @map("created_by") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // Relations
  guest             Guest              @relation(fields: [guestId], references: [id])
  session           RestaurantSession  @relation(fields: [sessionId], references: [id])
  creator           User?              @relation("CreatedByUser", fields: [createdBy], references: [id])
  reservationTables ReservationTable[]
  checkIn           CheckIn?
  payments          Payment[]

  @@index([date, sessionId], map: "idx_reservations_date_session")
  @@map("reservations")
}

model ReservationTable {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId String @map("reservation_id") @db.Uuid
  tableId       String @map("table_id") @db.Uuid

  // Relations
  reservation Reservation @relation(fields: [reservationId], references: [id])
  table       Table       @relation(fields: [tableId], references: [id])

  @@map("reservation_tables")
}

model CheckIn {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId String   @unique @map("reservation_id") @db.Uuid
  checkedInAt   DateTime @default(now()) @map("checked_in_at")
  checkedInBy   String?  @map("checked_in_by") @db.Uuid

  // Relations
  reservation Reservation @relation(fields: [reservationId], references: [id])
  checker     User?       @relation("CheckedInByUser", fields: [checkedInBy], references: [id])

  @@map("check_ins")
}

// -----------------------------------------------
// 6. PAYMENT RESERVASI
// -----------------------------------------------

model Payment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId   String        @map("reservation_id") @db.Uuid
  type            PaymentType
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus
  midtransOrderId String?       @unique @map("midtrans_order_id") @db.VarChar(100)
  midtransTxnId   String?       @map("midtrans_txn_id") @db.VarChar(100)
  paymentMethod   String?       @map("payment_method") @db.VarChar(50)
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@map("payments")
}

// -----------------------------------------------
// 8. KONTEN — GALERI & EVENT PUBLIK
// -----------------------------------------------

model GalleryPhoto {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url        String           @db.Text
  caption    String?          @db.VarChar(200)
  category   GalleryCategory?
  sortOrder  Int              @default(0) @map("sort_order")
  uploadedBy String?          @map("uploaded_by") @db.Uuid
  createdAt  DateTime         @default(now()) @map("created_at")

  // Relations
  uploader User? @relation("UploadedByUser", fields: [uploadedBy], references: [id])

  @@map("gallery_photos")
}

model GalleryImage {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.Text
  category    String   @db.VarChar(100)
  imageUrl    String   @map("image_url") @db.Text
  publicId    String   @map("public_id") @db.VarChar(255)
  width       Int?
  height      Int?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("gallery_images")
}

model Event {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String    @db.VarChar(200)
  description String?   @db.Text
  imageUrl    String?   @map("image_url") @db.Text
  eventDate   DateTime? @map("event_date") @db.Date
  isPublished Boolean   @default(false) @map("is_published")
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  creator User? @relation("CreatedByUser", fields: [createdBy], references: [id])

  @@map("events")
}

// -----------------------------------------------
// 9. KARIR
// -----------------------------------------------

model JobListing {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String   @db.VarChar(150)
  description  String?  @db.Text
  requirements String?  @db.Text
  isOpen       Boolean  @default(true) @map("is_open")
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  creator User? @relation("CreatedByUser", fields: [createdBy], references: [id])

  @@map("job_listings")
}

model CareerJob {
  id           String    @id @default(uuid()) @db.Uuid
  title        String    @db.VarChar(150)
  description  String    @db.Text
  requirements String    @db.Text
  deadline     DateTime?
  isOpen       Boolean   @default(true) @map("is_open")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  applications CareerApplication[]

  @@map("career_jobs")
}

model CareerApplication {
  id             String                  @id @default(uuid()) @db.Uuid
  jobId          String                  @map("job_id") @db.Uuid
  applicantName  String                  @map("applicant_name") @db.VarChar(100)
  applicantEmail String                  @map("applicant_email") @db.VarChar(150)
  applicantPhone String                  @map("applicant_phone") @db.VarChar(20)
  coverLetter    String?                 @map("cover_letter") @db.Text
  cvUrl          String                  @map("cv_url") @db.Text
  cvPublicId     String?                 @map("cv_public_id") @db.VarChar(255)
  status         CareerApplicationStatus @default(NEW)
  appliedAt      DateTime                @default(now()) @map("applied_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  // Relations
  job CareerJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("career_applications")
}

// -----------------------------------------------
// 10. NOTIFIKASI (browser push — admin & owner)
// -----------------------------------------------

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String?          @db.VarChar(200)
  body      String?          @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  relatedId String?          @map("related_id") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation("UserNotifications", fields: [userId], references: [id])

  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation("UserPushSubscriptions", fields: [userId], references: [id])

  @@map("push_subscriptions")
}

// -----------------------------------------------
// AUTH.JS V5 — NextAuth Models
// -----------------------------------------------

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id") @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model UserSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
