# Catatan Keamanan: Secret untuk production (termasuk VAPID, Cloudinary, Midtrans)
# wajib dikonfigurasi melalui environment Vercel/VPS, BUKAN ditulis di file repo.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"

# Docker Compose DB (VPS Deployment)
POSTGRES_USER="rooma_user"
POSTGRES_PASSWORD="CHANGE_ME_SECURE_PASSWORD"
POSTGRES_DB="rooma_db"
NEXT_PUBLIC_APP_URL="https://your-production-domain.com"

# Auth.js / NextAuth v5
# Generate a strong secret (e.g. openssl rand -base64 32)
AUTH_SECRET="CHANGE_ME"

# Web Push (VAPID) — admin/owner; generate: npx web-push generate-vapid-keys
# VAPID_SUBJECT harus mailto:... atau https://... (boleh URL publik situs)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT="mailto:admin@example.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Fonnte (WhatsApp) — Dev C
# Daftar: https://fonnte.com — dev boleh pakai nomor WA pribadi
FONNTE_TOKEN=
# Opsional: nomor device pengirim terdaftar di Fonnte
FONNTE_SENDER=

# Resend (Email) — Dev C + Career (Dev B)
# Daftar: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CAREER_ADMIN_EMAIL=

# Cron reminder H-1 — lindungi endpoint /api/cron/reminders
CRON_SECRET=

# Midtrans (Dev B)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Nonaktifkan telemetry Next.js di production VPS
NEXT_TELEMETRY_DISABLED=1
