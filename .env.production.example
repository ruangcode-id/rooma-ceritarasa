# ============================================================
# Rooma Ceritarasa — Production env template (VPS)
# ============================================================
# Salin ke VPS sebagai `.env.production` (JANGAN commit file berisi secret):
#   cp .env.production.example .env.production
#   chmod 600 .env.production
#
# Generate secrets:
#   openssl rand -base64 32   # AUTH_SECRET / CRON_SECRET / POSTGRES_PASSWORD

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ---- Postgres (Docker service name = db) ----
POSTGRES_USER=rooma_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=rooma_db
# DATABASE_URL digenerate otomatis di docker-compose.production.yml ke host `db`.
# Boleh diisi manual juga (opsional):
# DATABASE_URL=postgresql://rooma_user:CHANGE_ME_SECURE_PASSWORD@db:5432/rooma_db?schema=public

# ---- Public URL / Auth.js ----
# Sebelum domain ada: pakai http://IP_VPS (tanpa HTTPS otomatis)
# Setelah domain: https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
AUTH_URL=https://your-production-domain.com
AUTH_TRUST_HOST=true
AUTH_SECRET=replace-with-a-strong-random-secret

# ---- Caddy ----
# Domain: your-domain.com
# Sementara tanpa domain (HTTP saja): :80
SITE_ADDRESS=:80
ACME_EMAIL=admin@your-production-domain.com

# ---- Cron (panggil dari crontab VPS, bukan vercel.json) ----
CRON_SECRET=replace-with-a-strong-random-secret

# ---- Midtrans ----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Resend (email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CAREER_ADMIN_EMAIL=

# ---- Fonnte (WhatsApp) ----
FONNTE_TOKEN=
FONNTE_SENDER=

# ---- Web Push (opsional) ----
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@your-production-domain.com
